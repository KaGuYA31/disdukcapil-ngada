{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "prisma generate && prisma migrate deploy && prisma db seed && next build",
  "installCommand": "bun install",
  "regions": ["sin1"],
  "functions": {
    "src/app/api/**": {
      "maxDuration": 30
    }
  }
}
