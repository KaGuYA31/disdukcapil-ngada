// This is your Prisma schema file for Disdukcapil Ngada
// Compatible with PostgreSQL for Vercel deployment

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // For Vercel/Supabase
}

// Admin user for the admin panel
model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// News/Articles
model Berita {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String
  excerpt     String?
  thumbnail   String?
  category    String   @default("Umum")
  isPublished Boolean  @default(true)
  authorId    String?
  author      String?
  viewCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Services (Layanan)
model Layanan {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  description    String
  icon           String?
  requirements   String   // JSON string of requirements
  procedures     String   // JSON string of procedures
  forms          String?  // JSON string of form links
  faq            String?  // JSON string of FAQs
  processingTime String?
  fee            String?
  isActive       Boolean  @default(true)
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// Complaints/Pengaduan
model Pengaduan {
  id        String   @id @default(cuid())
  name      String
  nik       String?
  email     String?
  phone     String?
  subject   String
  message   String
  status    String   @default("Baru") // Baru, Diproses, Selesai
  response  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Announcements/Pengumuman
model Pengumuman {
  id        String   @id @default(cuid())
  title     String
  content   String
  type      String   @default("Info") // Info, Urgent, Maintenance
  startDate DateTime?
  endDate   DateTime?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Documents/Downloads for Transparansi
model Dokumen {
  id            String   @id @default(cuid())
  title         String
  description   String?
  category      String   // Peraturan, Laporan, SOP, Formulir
  fileUrl       String
  fileSize      String?
  fileType      String?
  downloadCount Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Site Statistics
model Statistik {
  id          String   @id @default(cuid())
  label       String
  value       String
  icon        String?
  description String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Organization Structure
model StrukturOrganisasi {
  id          String              @id @default(cuid())
  name        String
  position    String
  photo       String?
  description String?
  parentId    String?
  parent      StrukturOrganisasi? @relation("Hierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children    StrukturOrganisasi[] @relation("Hierarchy")
  order       Int                 @default(0)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

// Vision & Mission
model VisiMisi {
  id        String   @id @default(cuid())
  type      String   // "visi" or "misi"
  content   String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// History/Timeline
model Sejarah {
  id          String   @id @default(cuid())
  year        String
  title       String
  description String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Contact Information
model Kontak {
  id        String   @id @default(cuid())
  type      String   // phone, email, address, whatsapp, facebook, instagram, etc.
  value     String
  label     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
